<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Image Shop</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f4f4f4;
    }

    .container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      padding: 20px;
    }

    .card {
      background: white;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
      transition: transform 0.2s;
    }

    .card:hover {
      transform: scale(1.03);
    }

    .card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }

    .info {
      padding: 10px;
    }

    .name {
      font-size: 16px;
      font-weight: bold;
    }

    .price {
      color: green;
      margin-top: 5px;
    }
  </style>
</head>
<body>

<div class="container">

  <!-- Repeat this block 8 times -->
  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 1</div>
      <div class="price">$10.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 2</div>
      <div class="price">$15.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 3</div>
      <div class="price">$20.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 4</div>
      <div class="price">$25.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 5</div>
      <div class="price">$30.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 6</div>
      <div class="price">$35.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 7</div>
      <div class="price">$40.00</div>
    </div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300" alt="item">
    <div class="info">
      <div class="name">Item Name 8</div>
      <div class="price">$45.00</div>
    </div>
  </div>

</div>

</body>
</html>
